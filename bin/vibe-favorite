#!/usr/bin/env sh
set -eu

FAVORITES_DIR=${VIBE_FAVORITES_DIR:-$HOME/.local/share/vibe/favorites}
mkdir -p "$FAVORITES_DIR"

count_favorites() {
  find "$FAVORITES_DIR" -mindepth 1 -maxdepth 1 -print 2>/dev/null |
    awk 'END { print NR + 0 }'
}

case "${1:-}" in
  add)
    [ "$#" -eq 2 ] || exit 2
    TARGET=$2
    [ -e "$TARGET" ] || { printf 'Missing: %s\n' "$TARGET" >&2; exit 1; }
    TARGET=$(cd "$(dirname "$TARGET")" && printf '%s/%s\n' "$PWD" "$(basename "$TARGET")")
    BASE=$(basename "$TARGET")
    LINK=$FAVORITES_DIR/$BASE

    if [ -L "$LINK" ] && [ "$(readlink "$LINK")" = "$TARGET" ]; then
      printf 'Already saved: %s\n' "$BASE"
      exit 0
    fi

    NUMBER=2
    while [ -e "$LINK" ] || [ -L "$LINK" ]; do
      LINK=$FAVORITES_DIR/$BASE\ \($NUMBER\)
      NUMBER=$((NUMBER + 1))
    done

    ln -s "$TARGET" "$LINK"
    printf 'Saved: %s\n' "$(basename "$LINK")"
    ;;
  remove)
    [ "$#" -eq 2 ] || exit 2
    LINK=$2
    case "$LINK" in
      "$FAVORITES_DIR"/*) ;;
      *) printf 'Select an item in Favorites first.\n' >&2; exit 1 ;;
    esac
    [ -L "$LINK" ] || { printf 'Not a favorite: %s\n' "$(basename "$LINK")" >&2; exit 1; }
    NAME=$(basename "$LINK")
    rm "$LINK"
    printf 'Removed: %s\n' "$NAME"
    ;;
  count)
    count_favorites
    ;;
  title)
    [ "$#" -eq 2 ] || exit 2
    PANE=${VIBE_DIRECTORY_PANE:-${TMUX_PANE:-}}
    [ -n "$PANE" ] || exit 0
    case "$2" in
      favorites) LABEL="Favorites" ;;
      directory) LABEL="Explorer" ;;
      *) exit 2 ;;
    esac
    tmux set-option -p -t "$PANE" @vibe_role "$LABEL"
    ;;
  *)
    printf 'Usage: vibe-favorite {add PATH|remove LINK|count|title MODE}\n' >&2
    exit 2
    ;;
esac
