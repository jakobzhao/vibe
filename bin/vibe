#!/usr/bin/env sh
set -eu

resolve_script_dir() {
  SOURCE=$1
  while [ -L "$SOURCE" ]; do
    BASE=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd -P)
    SOURCE=$(readlink "$SOURCE")
    case "$SOURCE" in
      /*) ;;
      *) SOURCE="$BASE/$SOURCE" ;;
    esac
  done
  CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd -P
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

VIBE_BIN_DIR=$(resolve_script_dir "$0")
VIBE_ROOT=$(CDPATH= cd -- "$VIBE_BIN_DIR/.." && pwd -P)
FAVORITES_DIR=${VIBE_FAVORITES_DIR:-$HOME/.local/share/vibe/favorites}
mkdir -p "$FAVORITES_DIR"

usage() {
  cat <<'EOF'
Usage:
  vibe [DIR]
  vibe [--agent COMMAND]... [--worktree BRANCH] [DIR]
  vibe --list

Without options, vibe opens a lightweight terminal IDE in the current directory:
  Directory | Shell | Editor
  Codex             |

Set VIBE_EDITOR=nano for a one-session Nano Editor panel.

Options:
  -a, --agent COMMAND   Agent command to start (default: $VIBE_AGENT or codex).
                        Repeat to add agents in extra panes.
  -w, --worktree NAME  Work in an isolated Git worktree for NAME.
  -l, --list           List vibe sessions and their project paths.
  -h, --help           Show this help.

Session keys (press Ctrl-a, release, then press the second key):
  Ctrl-a d             Detach and leave vibe running.
  Ctrl-a Q             Quit vibe and stop the session (asks first).
  Ctrl-a h/j/k/l       Move between panels.

Examples:
  vibe
  vibe ~/code/project
  vibe -a codex -a claude ~/code/project
  vibe --worktree feature/login ~/code/project
EOF
}

attach_session() {
  if [ "${VIBE_NO_ATTACH:-0}" = 1 ]; then
    return 0
  fi
  if [ -n "${TMUX:-}" ]; then
    exec tmux switch-client -t "$1"
  fi
  exec tmux attach-session -t "$1"
}

list_sessions() {
  SESSIONS=$(tmux list-sessions -F '#{session_name}\t#{@vibe_dir}\t#{session_attached}' 2>/dev/null || true)
  VIBE_SESSIONS=$(printf '%s\n' "$SESSIONS" |
    awk -F '\t' '$1 ~ /^vibe-/ { printf "%-28s  %-8s  %s\n", $1, ($3 ? "attached" : "idle"), ($2 ? $2 : "-") }')
  if [ -z "$VIBE_SESSIONS" ]; then
    printf '%s\n' 'No vibe sessions.'
  else
    printf '%s\n' "$VIBE_SESSIONS"
  fi
}

AGENTS=
WORKTREE=
DIR=

while [ "$#" -gt 0 ]; do
  case "$1" in
    -a|--agent)
      [ "$#" -ge 2 ] || { printf '%s\n' 'vibe: --agent needs a command' >&2; exit 2; }
      AGENTS="${AGENTS}${AGENTS:+
}$2"
      shift 2
      ;;
    -w|--worktree)
      [ "$#" -ge 2 ] || { printf '%s\n' 'vibe: --worktree needs a branch name' >&2; exit 2; }
      WORKTREE=$2
      shift 2
      ;;
    -l|--list)
      list_sessions
      exit 0
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      [ "$#" -le 1 ] || { usage >&2; exit 2; }
      DIR=${1:-}
      break
      ;;
    -*)
      printf 'vibe: unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
    *)
      [ -z "$DIR" ] || { usage >&2; exit 2; }
      DIR=$1
      shift
      ;;
  esac
done

DIR=${DIR:-$PWD}
[ -d "$DIR" ] || { printf 'vibe: not a directory: %s\n' "$DIR" >&2; exit 1; }
DIR=$(cd "$DIR" && pwd -P)

if [ -n "$WORKTREE" ]; then
  ROOT=$(git -C "$DIR" rev-parse --show-toplevel 2>/dev/null) || {
    printf 'vibe: --worktree requires a Git repository: %s\n' "$DIR" >&2
    exit 1
  }
  REPO=$(basename "$ROOT")
  SAFE_BRANCH=$(printf '%s' "$WORKTREE" | tr '/. ' '---')
  WORKTREE_DIR="$(dirname "$ROOT")/$REPO-$SAFE_BRANCH"

  if [ ! -d "$WORKTREE_DIR" ]; then
    if git -C "$ROOT" show-ref --verify --quiet "refs/heads/$WORKTREE"; then
      git -C "$ROOT" worktree add "$WORKTREE_DIR" "$WORKTREE"
    else
      git -C "$ROOT" worktree add -b "$WORKTREE" "$WORKTREE_DIR"
    fi
  fi
  DIR=$(cd "$WORKTREE_DIR" && pwd -P)
fi

AGENTS=${AGENTS:-${VIBE_AGENT:-codex}}
VIBE_EDITOR=${VIBE_EDITOR:-nvim}
VIBE_COMPACT_UI=${VIBE_COMPACT_UI:-1}
VIBE_ANIMATIONS=${VIBE_ANIMATIONS:-1}
case "$VIBE_EDITOR" in
  nvim|nano) ;;
  *)
    printf 'vibe: unsupported VIBE_EDITOR: %s (use nvim or nano)\n' "$VIBE_EDITOR" >&2
    exit 2
    ;;
esac
case "$VIBE_COMPACT_UI" in
  0|1) ;;
  *)
    printf 'vibe: unsupported VIBE_COMPACT_UI: %s (use 0 or 1)\n' "$VIBE_COMPACT_UI" >&2
    exit 2
    ;;
esac
case "$VIBE_ANIMATIONS" in
  0|1) ;;
  *)
    printf 'vibe: unsupported VIBE_ANIMATIONS: %s (use 0 or 1)\n' "$VIBE_ANIMATIONS" >&2
    exit 2
    ;;
esac
command -v "$VIBE_EDITOR" >/dev/null 2>&1 || {
  printf 'vibe: editor not found: %s\n' "$VIBE_EDITOR" >&2
  exit 1
}
NAME=$(basename "$DIR" | tr '. ' '__')
# Include a portable checksum so projects with the same basename can coexist.
PROJECT_ID=$(printf '%s' "$DIR" | cksum | awk '{ print $1 }')
SESSION="vibe-$NAME-$PROJECT_ID"

if tmux has-session -t "=$SESSION" 2>/dev/null; then
  attach_session "$SESSION"
fi

while IFS= read -r AGENT; do
  [ -n "$AGENT" ] || continue
  EXECUTABLE=${AGENT%% *}
  if ! command -v "$EXECUTABLE" >/dev/null 2>&1; then
    printf 'vibe: agent command not found: %s\n' "$EXECUTABLE" >&2
    exit 1
  fi
done <<EOF
$AGENTS
EOF

# Build at the invoking terminal's real size. A detached tmux session otherwise
# starts at 80x24 and distributes later growth evenly, which distorts the pane
# percentages on large terminals.
INITIAL_WIDTH=${COLUMNS:-}
INITIAL_HEIGHT=${LINES:-}
if [ -n "${TMUX:-}" ]; then
  INITIAL_WIDTH=$(tmux display-message -p '#{client_width}' 2>/dev/null || true)
  INITIAL_HEIGHT=$(tmux display-message -p '#{client_height}' 2>/dev/null || true)
fi
[ -n "$INITIAL_WIDTH" ] || INITIAL_WIDTH=$(tput cols 2>/dev/null || true)
[ -n "$INITIAL_HEIGHT" ] || INITIAL_HEIGHT=$(tput lines 2>/dev/null || true)
case "$INITIAL_WIDTH" in ''|*[!0-9]*) INITIAL_WIDTH=80 ;; esac
case "$INITIAL_HEIGHT" in ''|*[!0-9]*) INITIAL_HEIGHT=24 ;; esac
[ "$INITIAL_WIDTH" -ge 20 ] || INITIAL_WIDTH=80
[ "$INITIAL_HEIGHT" -ge 10 ] || INITIAL_HEIGHT=24

# Build the workspace behind a loading window, then reveal it only after every
# program has painted its first interactive frame.
MAIN_PANE=$(tmux new-session -d -x "$INITIAL_WIDTH" -y "$INITIAL_HEIGHT" -P -F '#{pane_id}' -s "$SESSION" -c "$DIR" -n cockpit)
tmux set-option -t "$SESSION" status off
tmux set-option -t "$SESSION" @vibe_dir "$DIR"
tmux set-option -t "$SESSION" @vibe_agents "$(printf '%s' "$AGENTS" | tr '\n' ',')"
tmux set-option -t "$SESSION" @vibe_ready 0
if [ "${VIBE_NO_ATTACH:-0}" = 1 ]; then
  tmux set-option -t "$SESSION" remain-on-exit on
fi

LOADING_PANE=$(tmux new-window -P -F '#{pane_id}' -t "$SESSION" -n loading -c "$DIR")
LOADING_COMMAND="exec $(shell_quote "$VIBE_BIN_DIR/vibe-loading") $(shell_quote "$SESSION")"
tmux respawn-pane -k -t "$LOADING_PANE" -c "$DIR" "$LOADING_COMMAND"
tmux select-window -t "$SESSION:loading"

# Match the default cockpit's visual balance: Editor gets roughly three fifths
# of the window; the left side splits evenly by height, with Shell and
# Directory sharing the upper row equally.
DIR_PANE=$(tmux split-window -h -b -l 38% -P -F '#{pane_id}' -t "$MAIN_PANE" -c "$DIR")
AI_PANE=$(tmux split-window -v -l 51% -P -F '#{pane_id}' -t "$DIR_PANE" -c "$DIR")
SHELL_PANE=$(tmux split-window -h -b -l 50% -P -F '#{pane_id}' -t "$DIR_PANE" -c "$DIR")

SOCKET_ROOT=${TMPDIR:-/tmp}
SOCKET_ROOT=${SOCKET_ROOT%/}
SOCKET="$SOCKET_ROOT/vibe-$(id -u)-$PROJECT_ID.sock"
tmux set-environment -t "$SESSION" VIBE_NVIM_SOCKET "$SOCKET"
tmux set-environment -t "$SESSION" VIBE_MAIN_PANE "$MAIN_PANE"
tmux set-environment -t "$SESSION" VIBE_DIRECTORY_PANE "$DIR_PANE"
tmux set-environment -t "$SESSION" VIBE_SHELL_PANE "$SHELL_PANE"
tmux set-environment -t "$SESSION" VIBE_EDITOR "$VIBE_EDITOR"
tmux set-environment -t "$SESSION" VIBE_COMPACT_UI "$VIBE_COMPACT_UI"
tmux set-environment -t "$SESSION" VIBE_ANIMATIONS "$VIBE_ANIMATIONS"
tmux set-environment -t "$SESSION" YAZI_CONFIG_HOME "$VIBE_ROOT/yazi"
tmux set-environment -t "$SESSION" EDITOR "$VIBE_BIN_DIR/vibe-open"
tmux set-environment -t "$SESSION" VIBE_PROJECT_DIR "$DIR"
tmux set-environment -t "$SESSION" VIBE_FAVORITES_DIR "$FAVORITES_DIR"
tmux set-environment -t "$SESSION" VIBE_FAVORITE_HELPER "$VIBE_BIN_DIR/vibe-favorite"

tmux select-pane -t "$MAIN_PANE" -T 'Editor'
tmux select-pane -t "$DIR_PANE" -T 'Directory'
tmux select-pane -t "$SHELL_PANE" -T 'Shell'
tmux set-option -p -t "$MAIN_PANE" @vibe_role 'Editor'
FAVORITES_COUNT=$(VIBE_FAVORITES_DIR="$FAVORITES_DIR" "$VIBE_BIN_DIR/vibe-favorite" count)
tmux set-option -p -t "$DIR_PANE" @vibe_role "Directory · Favorites: $FAVORITES_COUNT"
tmux set-option -p -t "$DIR_PANE" @vibe_favorites_click 1
tmux set-option -p -t "$SHELL_PANE" @vibe_role 'Shell'
MAIN_COMMAND="exec env VIBE_EDITOR=$(shell_quote "$VIBE_EDITOR") VIBE_COMPACT_UI=$(shell_quote "$VIBE_COMPACT_UI") VIBE_ANIMATIONS=$(shell_quote "$VIBE_ANIMATIONS") VIBE_NVIM_SOCKET=$(shell_quote "$SOCKET") VIBE_MAIN_PANE=$(shell_quote "$MAIN_PANE") VIBE_NVIM_CONFIG=$(shell_quote "$VIBE_ROOT/nvim/vibe.lua") $(shell_quote "$VIBE_BIN_DIR/vibe-main")"
DIRECTORY_COMMAND="exec env VIBE_EDITOR=$(shell_quote "$VIBE_EDITOR") VIBE_NVIM_SOCKET=$(shell_quote "$SOCKET") VIBE_MAIN_PANE=$(shell_quote "$MAIN_PANE") VIBE_DIRECTORY_PANE=$(shell_quote "$DIR_PANE") VIBE_PROJECT_DIR=$(shell_quote "$DIR") VIBE_FAVORITES_DIR=$(shell_quote "$FAVORITES_DIR") VIBE_FAVORITE_HELPER=$(shell_quote "$VIBE_BIN_DIR/vibe-favorite") YAZI_CONFIG_HOME=$(shell_quote "$VIBE_ROOT/yazi") EDITOR=$(shell_quote "$VIBE_BIN_DIR/vibe-open") yazi ."
SHELL_COMMAND="exec $(shell_quote "$VIBE_BIN_DIR/vibe-shell")"
tmux send-keys -t "$MAIN_PANE" -l "$MAIN_COMMAND"
tmux send-keys -t "$MAIN_PANE" Enter
tmux send-keys -t "$DIR_PANE" -l "$DIRECTORY_COMMAND"
tmux send-keys -t "$DIR_PANE" Enter
tmux respawn-pane -k -t "$SHELL_PANE" -c "$DIR" "$SHELL_COMMAND"

FIRST=1
READY_SPECS=
while IFS= read -r AGENT; do
  [ -n "$AGENT" ] || continue
  LABEL=${AGENT%% *}
  LABEL=$(basename "$LABEL")

  if [ "$FIRST" -eq 1 ]; then
    PANE=$AI_PANE
    FIRST=0
  else
    PANE=$(tmux split-window -v -P -F '#{pane_id}' -t "$AI_PANE" -c "$DIR")
  fi

  case "$LABEL" in
    codex) PANE_TITLE='Codex' ;;
    claude) PANE_TITLE='Claude' ;;
    gemini) PANE_TITLE='Gemini' ;;
    opencode) PANE_TITLE='OpenCode' ;;
    aider) PANE_TITLE='Aider' ;;
    *) PANE_TITLE=$LABEL ;;
  esac
  tmux select-pane -t "$PANE" -T "$PANE_TITLE"
  tmux set-option -p -t "$PANE" @vibe_role "$PANE_TITLE"
  case "$LABEL" in
    codex)
      AGENT="$AGENT -c tui.animations=false -c tui.show_tooltips=false"
      if [ "$VIBE_COMPACT_UI" = 1 ]; then
        AGENT="$AGENT -c 'tui.status_line=[]'"
      fi
      ;;
  esac
  tmux respawn-pane -k -t "$PANE" -c "$DIR" "$AGENT"
  READY_SPECS="$READY_SPECS $(shell_quote "$PANE:$LABEL")"
done <<EOF
$AGENTS
EOF

tmux select-pane -t "$DIR_PANE"
READY_COMMAND="exec $(shell_quote "$VIBE_BIN_DIR/vibe-ready") $(shell_quote "$SESSION") $(shell_quote "$SOCKET") $(shell_quote "$DIR_PANE") $(shell_quote "$MAIN_PANE")$READY_SPECS"
tmux run-shell -b "$READY_COMMAND"
attach_session "$SESSION"
