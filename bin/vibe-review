#!/usr/bin/env sh
set -u

ACTION=${1:-}
PROJECT_DIR=${VIBE_PROJECT_DIR:-$PWD}
SOCKET=${VIBE_NVIM_SOCKET:-}
EDITOR_PANE=${VIBE_MAIN_PANE:-}

case "$ACTION" in
  open)
    [ -n "$SOCKET" ] && [ -S "$SOCKET" ] || {
      tmux display-message 'Editor is not ready.' 2>/dev/null || true
      exit 1
    }
    nvim --server "$SOCKET" --remote-send '<Cmd>VibeReview<CR>'
    if [ -n "$EDITOR_PANE" ]; then
      tmux select-window -t "$EDITOR_PANE"
      tmux select-pane -t "$EDITOR_PANE"
    fi
    ;;
  test)
    if [ -n "${VIBE_TEST_COMMAND:-}" ]; then
      TEST_COMMAND=$VIBE_TEST_COMMAND
    elif [ -x "$PROJECT_DIR/tests/check.sh" ]; then
      TEST_COMMAND=./tests/check.sh
    elif [ -f "$PROJECT_DIR/package.json" ]; then
      TEST_COMMAND='npm test'
    elif [ -f "$PROJECT_DIR/Cargo.toml" ]; then
      TEST_COMMAND='cargo test'
    elif [ -f "$PROJECT_DIR/go.mod" ]; then
      TEST_COMMAND='go test ./...'
    elif [ -f "$PROJECT_DIR/pyproject.toml" ] || [ -d "$PROJECT_DIR/tests" ]; then
      TEST_COMMAND='pytest'
    elif [ -f "$PROJECT_DIR/Makefile" ]; then
      TEST_COMMAND='make test'
    else
      printf '\n  Vibe could not detect a test command.\n'
      printf '  Set VIBE_TEST_COMMAND before starting Vibe.\n\n'
      printf '  Press Enter to close.'
      IFS= read -r _
      exit 1
    fi

    printf '\n  V I B E   T E S T\n\n  > %s\n\n' "$TEST_COMMAND"
    cd "$PROJECT_DIR" || exit 1
    "${SHELL:-/bin/sh}" -lc "$TEST_COMMAND"
    STATUS=$?
    printf '\n  Test command exited with status %s.\n' "$STATUS"
    printf '  Press Enter to close.'
    IFS= read -r _
    exit "$STATUS"
    ;;
  *)
    printf 'Usage: vibe-review {open|test}\n' >&2
    exit 2
    ;;
esac
