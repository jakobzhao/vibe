#!/usr/bin/env sh
set -eu

ACTION=${1:-}
CLIENT=${2:-}
PROJECT_DIR=${VIBE_PROJECT_DIR:-$PWD}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

case "$ACTION" in
  shell)
    HELPER=${VIBE_SHELL_HELPER:?vibe-popup: VIBE_SHELL_HELPER is not set}
    COMMAND="exec $(shell_quote "$HELPER")"
    WIDTH=82%
    HEIGHT=72%
    WINDOW_NAME=shell
    ;;
  test)
    HELPER=${VIBE_REVIEW_HELPER:?vibe-popup: VIBE_REVIEW_HELPER is not set}
    COMMAND="exec $(shell_quote "$HELPER") test"
    WIDTH=88%
    HEIGHT=80%
    WINDOW_NAME=test
    ;;
  *)
    printf 'Usage: vibe-popup {shell|test} [CLIENT]\n' >&2
    exit 2
    ;;
esac

if tmux list-commands | grep -q '^display-popup '; then
  if [ -n "$CLIENT" ]; then
    tmux display-popup -t "$CLIENT" -E -w "$WIDTH" -h "$HEIGHT" -d "$PROJECT_DIR" "$COMMAND"
  else
    tmux display-popup -E -w "$WIDTH" -h "$HEIGHT" -d "$PROJECT_DIR" "$COMMAND"
  fi
else
  SESSION=${TMUX_PANE:+$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}')}
  SESSION=${SESSION:-$(tmux display-message -p '#{session_name}')}
  tmux new-window -t "$SESSION" -n "$WINDOW_NAME" -c "$PROJECT_DIR" "$COMMAND"
fi
